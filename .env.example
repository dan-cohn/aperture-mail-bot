# ── GCP ────────────────────────────────────────────────────────────
GCP_PROJECT_ID=aperture-prod-20260221
FIRESTORE_DATABASE=aperture-db
PUBSUB_TOPIC=aperture-gmail-push
PUBSUB_SUBSCRIPTION=aperture-gmail-push-sub

# ── Telegram ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=your-chat-id          # Get from @userinfobot

# ── LLM ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
LLM_PROVIDER=gemini                    # gemini | claude | openai

# ── Cloud Run (fill in after first deployment) ────────────────────────
CLOUD_RUN_URL=https://aperture-xxxx-uc.a.run.app

# ── App ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_SECRET=your-random-secret-here
TIMEZONE=America/New_York
LOG_LEVEL=INFO
ENVIRONMENT=production
